# ============================================================
# AngeVoice 环境变量模板
# 复制为 .env.dev / .env.staging / .env.prod 后修改
# docker-compose 通过 env_file 加载
# ============================================================

# ---- 基础服务 ----
# KOKORO_HOST=0.0.0.0                # 监听地址
# KOKORO_PORT=8000                    # 容器内端口（宿主机映射在 docker-compose 中配置）
# KOKORO_DEVICE=cpu                   # 推理设备: cpu / cuda / mps
# KOKORO_WORKERS=1                    # uvicorn worker 数量（GPU 模式建议保持 1）

# ---- 模型路径 ----
# KOKORO_MODEL_DIR=/app/models        # 模型目录（容器内路径）
# HF_HOME=/root/.cache/huggingface    # HuggingFace 缓存根目录
# HUGGINGFACE_HUB_CACHE=/root/.cache/huggingface/hub
# ANGEVOICE_MODEL_SOURCE=auto             # auto/huggingface/modelscope；先探测 HF/ModelScope 可达性，再做国家判断
# KOKORO_MODELSCOPE_REPO=AI-ModelScope/Kokoro-82M-v1.1-zh
# MOSS_MODELSCOPE_REPO=openmoss/MOSS-TTS-Nano-100M-ONNX

# ---- 合成参数 ----
# KOKORO_MAX_TEXT_LENGTH=10000        # 单次合成最大字符数
# KOKORO_SEGMENT_LENGTH=160
# KOKORO_DEFAULT_VOICE=zm_010         # 默认音色
# KOKORO_DEFAULT_SPEED=1.0            # 默认语速 (0.5 ~ 2.0)
# KOKORO_REQUEST_TIMEOUT_SECONDS=300  # 单次请求超时（秒）
# KOKORO_MAX_CONCURRENT_REQUESTS=1    # 最大并发请求数

# ---- 流式合成 ----
# KOKORO_STREAM_FORMAT=pcm_s16le      # 流式格式: pcm_s16le / wav
# KOKORO_STREAM_BINARY_ENABLED=true   # 二进制帧模式（减少 JSON 开销）
# KOKORO_STREAM_CHUNK_SECONDS=0.55

# ---- 缓存 ----
# KOKORO_CACHE_ENABLED=true           # 启用合成结果缓存
# KOKORO_CACHE_MAX_ITEMS=64          # 最大缓存条目

# ---- 批量合成 ----
# KOKORO_BATCH_ENABLED=true           # 启用 /v1/audio/batch 端点
# KOKORO_BATCH_MAX_ITEMS=20           # 单次批量最大条目数
# KOKORO_BATCH_CONCURRENCY=1          # 批量并发数

# ---- MP3 输出 ----
# KOKORO_MP3_ENABLED=false            # 启用 MP3 格式（需容器内有 ffmpeg）
# KOKORO_MP3_BITRATE=192k             # MP3 码率: 64k/96k/128k/160k/192k/256k/320k

# ---- MOSS-TTS-Nano ----
# ANGEVOICE_ENABLED_MODELS=kokoro,moss-nano-cpu  # GPU 镜像可加入 moss-nano-cuda
# ANGEVOICE_DEFAULT_MODEL=kokoro                 # 默认仍使用 Kokoro，MOSS 在 Web UI 切换
# MOSS_MODEL_DIR=/opt/MOSS-TTS-Nano/models       # MOSS 模型持久化目录
# MOSS_EXECUTION_PROVIDER=cpu                    # cpu / cuda
# MOSS_CUDA_ENABLED=false                        # CPU/legacy 默认关闭 CUDA MOSS
# MOSS_CUDA_MEMORY_LIMIT_MB=0                    # 默认不限显存；仅小显存排障时手动设置
# MOSS_CPU_THREADS=2                             # NAS/低功耗设备建议 2-4
# MOSS_SAMPLE_MODE=fixed
# MOSS_SEED=1234
# MOSS_STREAM_CHUNK_SECONDS=0.40
# MOSS_STREAM_QUEUE_MAX_ITEMS=4
# MOSS_PROMPT_UPLOAD_MAX_BYTES=20971520          # 克隆参考音频上传上限
# MOSS_PROMPT_AUDIO_MAX_SECONDS=8               # 参考音频会裁剪到该时长，降低显存和延迟
# MOSS_PROMPT_CACHE_MAX_ITEMS=8                  # 缓存参考音频编码，减少重复 clone 开销
# MOSS_OUTPUT_PEAK_NORMALIZE_ENABLED=true        # MOSS 输出削峰，降低爆音/削波
# MOSS_OUTPUT_TARGET_PEAK=0.78
# MOSS_OUTPUT_GAIN=0.88

# ---- 监控 & 状态 ----
# KOKORO_METRICS_ENABLED=true         # /stats 端点
# KOKORO_QUEUE_STATUS_ENABLED=true    # /requests 端点

# ---- 管理 API ----
# KOKORO_ADMIN_ENABLED=false          # 启用 /admin/* 端点（缓存清理、音色上传等）
# KOKORO_API_KEY=auto                # API Key；auto=首次启动生成并持久化，留空=无认证
# ANGEVOICE_API_KEY_FILE=/app/outputs/.angevoice-api-key
# ANGEVOICE_RUNTIME_CONFIG_FILE=/app/outputs/runtime-config.json
# KOKORO_VOICE_UPLOAD_ENABLED=false   # 启用音色文件上传
# KOKORO_VOICE_UPLOAD_MAX_BYTES=10485760  # 上传大小限制（默认 10MB）

# ---- CORS ----
# KOKORO_CORS_ORIGINS=*               # 允许的来源，逗号分隔
# KOKORO_TRUST_PROXY_HEADERS=false
# KOKORO_PUBLIC_STATUS_ENDPOINTS=true     # 公开模型/音色列表；公网敏感部署可设 false

# ---- Python ----
# PYTHONUNBUFFERED=1                  # 禁用输出缓冲（日志实时输出）

# Allow the normal Bearer API key to access /admin. Keep false when API keys are shared with clients.

# AngeVoice 长文本自然合成优化
# Kokoro 流式首包预缓冲，减少浏览器播放断流感
# KOKORO_STREAM_PREBUFFER_SECONDS=0.25
# MOSS_SEGMENT_LENGTH=180
# MOSS_MAX_NEW_FRAMES=320
# MOSS_VOICE_CLONE_MAX_TEXT_TOKENS=64
# MOSS 流式首包预缓冲，长文本更不容易听到断流
# MOSS_STREAM_PREBUFFER_SECONDS=0.45
# MOSS_OUTPUT_EDGE_FADE_MS=3
# MOSS 音频自然化后处理：静音压缩 + crossfade + trim
# MOSS_AUDIO_POLISH_ENABLED=true
# 裁掉 chunk 首尾异常静音，减少长文本卡顿
# MOSS_TRIM_SILENCE_ENABLED=true
# 低于该 dBFS 视为静音边缘
# MOSS_TRIM_SILENCE_DB=-45
# 最终音频连续静音上限，超过会被压缩
# MOSS_MAX_SILENCE_MS=850
# 非流式拼接 crossfade 时长
# MOSS_CROSSFADE_MS=25
# AngeVoice 外层文本段之间补充的自然短停顿
# MOSS_SEGMENT_PAUSE_MS=100
# MOSS runtime chunk pause 上限，防止 2-5 秒空白
# MOSS_RUNTIME_PAUSE_MAX_MS=500

# 缓存保护：长文本命中率低，默认限制内存占用
KOKORO_CACHE_MAX_BYTES=536870912
KOKORO_CACHE_SKIP_TEXT_OVER_CHARS=1200
KOKORO_CACHE_SKIP_AUDIO_OVER_BYTES=20971520

# 中文网页/小说硬换行策略：auto 会合并段内单换行，保留空行段落
ANGEVOICE_SINGLE_NEWLINE_POLICY=auto

# MOSS 显存保护：8GB/P4/NAS 推荐保持开启
MOSS_VRAM_GUARD_ENABLED=true
MOSS_VRAM_SAFE_FREE_MB=1200
MOSS_VRAM_CRITICAL_FREE_MB=600
MOSS_LOW_VRAM_SEGMENT_LENGTH=160
MOSS_LOW_VRAM_MAX_NEW_FRAMES=300
MOSS_LOW_VRAM_TEXT_TOKENS=56
MOSS_DISABLE_FULL_CODEC_AFTER_OOM=true
MOSS_FULL_CODEC_OOM_COOLDOWN_SECONDS=600
