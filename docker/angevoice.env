# ============================================================
# AngeVoice Docker 默认配置
# 适用版本：AngeVoice 2.6.5.1
# 适用画像：CPU / NAS / 家用服务器默认场景
# 说明：GPU 与 legacy-gpu 的差异会在各自 docker-compose.yml 中覆盖
#
# 安全等级说明：
#   [MUST] 公网/生产部署必须确认或修改
#   [REC]  推荐按实际环境调整
#   [OPT]  可选项，默认值对大多数场景已够用
#
# 设计原则：
#   - 开箱配置尽量少改；Docker 默认保留 admin/admin123 方便 NAS 首次进入后台；公网部署必须改强密码
#   - 默认偏向 CPU/NAS 稳定、省内存、省功耗
#   - 公网部署相关风险用注释明确标出
#   - 不包含真实 API Key；后台默认密码 admin123 仅适合内网首次启动
# ============================================================


# ────────────────────────────────────────────────────────────
# 一、基础服务
# ────────────────────────────────────────────────────────────

PYTHONUNBUFFERED=1
KOKORO_HOST=0.0.0.0
KOKORO_PORT=8000

# [REC] CPU/NAS 场景保持 1；多卡或高显存服务器可按需提高。
KOKORO_WORKERS=1
KOKORO_MAX_CONCURRENT_REQUESTS=1
KOKORO_REQUEST_TIMEOUT_SECONDS=300

# 单位：字符。过大可能导致长请求占用 CPU/GPU 过久。
KOKORO_MAX_TEXT_LENGTH=10000

# Kokoro 通用分段长度。
# Kokoro 对较短分段更友好，默认 100。
KOKORO_SEGMENT_LENGTH=160

KOKORO_DEFAULT_VOICE=zm_010
KOKORO_DEFAULT_SPEED=1.0

# [MUST] 公网部署必须改成你的前端域名，例如：
#   KOKORO_CORS_ORIGINS=https://tts.example.com
# 默认 * 仅适合内网/NAS 快速启动或受信任反向代理后使用。
KOKORO_CORS_ORIGINS=*


# ────────────────────────────────────────────────────────────
# 二、模型与输出
# ────────────────────────────────────────────────────────────

ANGEVOICE_ENABLED_MODELS=kokoro,moss-nano-cpu
ANGEVOICE_DEFAULT_MODEL=kokoro

ANGEVOICE_OUTPUT_DIR=/app/outputs
ANGEVOICE_RUNTIME_CONFIG_FILE=/app/outputs/runtime-config.json
ANGEVOICE_SAVE_OUTPUTS=true

# [REC] 按磁盘容量调整；500 个音频文件通常比 1000 更适合 NAS 默认值。
# 如只做 API 临时输出，可改小；如做批量合成归档，可改大。
ANGEVOICE_OUTPUT_MAX_FILES=500

# 模型源：
#   auto        = 自动探测 Hugging Face / ModelScope 可达性后选择
#   huggingface = 强制使用 Hugging Face
#   modelscope  = 强制使用 ModelScope
ANGEVOICE_MODEL_SOURCE=auto
KOKORO_MODELSCOPE_REPO=AI-ModelScope/Kokoro-82M-v1.1-zh
MOSS_MODELSCOPE_REPO=openmoss/MOSS-TTS-Nano-100M-ONNX


# ────────────────────────────────────────────────────────────
# 三、空闲卸载：NAS / 低功耗场景
# ────────────────────────────────────────────────────────────

# 无请求 10 分钟后自动释放所有已加载模型，降低内存、显存与功耗。
# [REC] 常驻高可用场景可改为 0，表示关闭自动卸载。
ANGEVOICE_IDLE_TIMEOUT_SECONDS=600
ANGEVOICE_IDLE_CHECK_INTERVAL=30
ANGEVOICE_IDLE_UNLOAD_CURRENT=true


# ────────────────────────────────────────────────────────────
# 四、MOSS-TTS-Nano：保守稳定配置
# ────────────────────────────────────────────────────────────

MOSS_MODEL_DIR=/opt/MOSS-TTS-Nano/models
MOSS_EXECUTION_PROVIDER=cpu
MOSS_CUDA_ENABLED=false
MOSS_CUDA_MEMORY_LIMIT_MB=0

# [REC] NAS/低功耗 CPU 建议 2；独立服务器可尝试 4。
MOSS_CPU_THREADS=2

MOSS_DEFAULT_VOICE=Junhao

# MOSS 专用分段长度。默认 120 为 NAS/P4 稳定档；高显存机器可在后台切换长文本旁白预设到 180-260。
MOSS_SEGMENT_LENGTH=120

# 参考音频上传限制。
MOSS_PROMPT_UPLOAD_MAX_BYTES=20971520
MOSS_PROMPT_AUDIO_MAX_SECONDS=8
MOSS_PROMPT_CACHE_MAX_ITEMS=8

# 保守默认，长文本质量和稳定性优先。
MOSS_MAX_NEW_FRAMES=320

# 单次 MOSS 声音克隆最大 token 数。
# 注意：这是 token，不是字符；不要和 KOKORO_MAX_TEXT_LENGTH 混淆。
MOSS_VOICE_CLONE_MAX_TEXT_TOKENS=56

# fixed = 固定种子，输出更稳定、可复现。
# 如果想要更多随机语气，可尝试：
MOSS_SAMPLE_MODE=fixed
MOSS_SEED=1234

# WeText 文本规范化：
# true  可改善数字、日期、单位读法；
# false 更少误处理型号、API、IP、版本号、英文缩写，默认更稳。
MOSS_ENABLE_WETEXT_PROCESSING=false

# [REC] auto 会对中文为主文本使用完整规则，对中英文/技术文本保守处理，减少版本号、API、英文缩写读坏。
MOSS_ENABLE_NORMALIZE_TTS_TEXT=true
MOSS_APPLY_ANGEVOICE_RULES=auto
# MOSS 中英文混排策略：translate 会把常见英文词组转成自然中文，preserve 保留原文。
MOSS_MIXED_ENGLISH_POLICY=translate

# 流式解码：
#   true  = 默认推荐，更低首包延迟、Web/小智体感更好
#   false = 质量优先，首包更慢；若逐帧出现电流音/卡顿可回退
MOSS_REALTIME_STREAMING_DECODE=true

# 0.40 秒兼顾首包速度和听感连续性；过小容易碎片化。
MOSS_STREAM_CHUNK_SECONDS=0.40
MOSS_STREAM_QUEUE_MAX_ITEMS=8

MOSS_AUTO_FALLBACK_CPU=true
MOSS_CUDA_SELF_TEST_ENABLED=true
MOSS_QUALITY_GATE_ENABLED=true

# 音频输出后处理：更自然的轻增益 + 温和峰值保护，避免声音过低或硬削峰失真。
MOSS_OUTPUT_PEAK_NORMALIZE_ENABLED=true
MOSS_OUTPUT_TARGET_PEAK=0.86
MOSS_OUTPUT_GAIN=0.94
MOSS_OUTPUT_DECLICK_ENABLED=true
MOSS_OUTPUT_EDGE_FADE_MS=1.5

# 进程级隔离：
#   false = 默认，减少 NAS/CPU 进程通信和重载开销
#   true  = 遇到 CUDA/ONNX Runtime 卡死或多租户隔离需求时启用
#
# CPU 默认不建议开启；GPU/legacy-gpu 如果启用 MOSS CUDA 且遇到卡死，可开启。
MOSS_PROCESS_ISOLATION_ENABLED=false
MOSS_PROCESS_ISOLATION_PROVIDERS=cuda
MOSS_PROCESS_KILL_GRACE_SECONDS=2

# MOSS 流式预算阈值，单位：秒。
# 用于控制动态解码和分包节奏，普通用户无需修改。
MOSS_STREAM_BUDGET_THRESHOLD_LOW=0.25
MOSS_STREAM_BUDGET_THRESHOLD_MID=0.65
MOSS_STREAM_BUDGET_THRESHOLD_HIGH=1.20
MOSS_STREAM_CHUNK_MIN_FLOOR=0.10


# ────────────────────────────────────────────────────────────
# 五、WebSocket 流式
# ────────────────────────────────────────────────────────────

KOKORO_STREAM_FORMAT=pcm_s16le
KOKORO_STREAM_BINARY_ENABLED=true
KOKORO_STREAM_CHUNK_SECONDS=0.55


# ────────────────────────────────────────────────────────────
# 六、缓存、状态、批量
# ────────────────────────────────────────────────────────────

KOKORO_CACHE_ENABLED=true
KOKORO_CACHE_MAX_ITEMS=64

KOKORO_METRICS_ENABLED=true
KOKORO_QUEUE_STATUS_ENABLED=true

KOKORO_BATCH_ENABLED=true
KOKORO_BATCH_MAX_ITEMS=20
KOKORO_BATCH_CONCURRENCY=1


# ────────────────────────────────────────────────────────────
# 七、限流、队列与公开状态接口
# ────────────────────────────────────────────────────────────

# [MUST] 公网部署不要保留 0。
# 建议公网起步值：
#   KOKORO_RATE_LIMIT_QPS=5
#   KOKORO_RATE_LIMIT_BURST=10
#
# 0 = 关闭限流，仅适合可信内网或反代已做限流的环境。
KOKORO_RATE_LIMIT_QPS=0
KOKORO_RATE_LIMIT_BURST=5

# 0 = 不限制全局排队/在途请求。
# [REC] 公网或多人共享建议设置 50–100，避免请求堆积拖垮服务。
KOKORO_MAX_QUEUE_LENGTH=0

# [MUST] 默认不信任 X-Forwarded-For，避免裸露公网时被伪造 IP 绕过限流。
# 只有确认服务运行在可信 Nginx/Caddy/Traefik 等反代后面时，才改为 true。
KOKORO_TRUST_PROXY_HEADERS=false

# 公开状态接口：
#   true  = /v1/models、/v1/audio/voices 等状态接口公开，适合内网/NAS 易用场景
#   false = 这些接口需要 Bearer Token，公网敏感部署建议关闭
#
# 注意：/health 会保留最小健康检查输出，方便 Docker / 反代探活。
KOKORO_PUBLIC_STATUS_ENDPOINTS=true


# ────────────────────────────────────────────────────────────
# 八、管理后台
# ────────────────────────────────────────────────────────────

# 管理后台已开启。
KOKORO_ADMIN_ENABLED=true
ANGEVOICE_ADMIN_USERNAME=admin
ANGEVOICE_ADMIN_PASSWORD=admin123

# [REC] 普通 TTS API Key 与管理权限应分离。
# false = 普通 Bearer API Key 不能访问 /admin，推荐默认值
# true  = 允许普通 API Key 访问 /admin，仅适合完全自用环境
KOKORO_ADMIN_ALLOW_API_KEY=false


# ────────────────────────────────────────────────────────────
# 九、认证
# ────────────────────────────────────────────────────────────

# auto = 启动时自动生成 API Key，并写入 ANGEVOICE_API_KEY_FILE。
# 这样普通用户无需手动编辑 env 也能安全启动。
#
# 查看命令：
#   docker exec <container> cat /app/outputs/.angevoice-api-key
#
# 如果你想固定密钥，也可以直接改成：
#   KOKORO_API_KEY=your-long-random-secret
KOKORO_API_KEY=auto
ANGEVOICE_API_KEY_FILE=/app/outputs/.angevoice-api-key


# ────────────────────────────────────────────────────────────
# 十、可选功能
# ────────────────────────────────────────────────────────────

# Kokoro .pt 音色上传默认关闭。
# [MUST] 不建议在公网开启；如必须开启，请放在内网管理入口或反代白名单后。
KOKORO_VOICE_UPLOAD_ENABLED=false
KOKORO_VOICE_UPLOAD_MAX_BYTES=10485760

# MP3 输出需要 ffmpeg。
# [OPT] NAS 磁盘敏感、需要长期保存输出时可开启。
KOKORO_MP3_ENABLED=false
KOKORO_MP3_BITRATE=192k

# AngeVoice 长文本自然合成优化
# Kokoro 流式首包预缓冲，减少浏览器播放断流感
KOKORO_STREAM_PREBUFFER_SECONDS=0.25
# MOSS 流式首包预缓冲，长文本更不容易听到断流
MOSS_STREAM_PREBUFFER_SECONDS=0.75
# MOSS 音频自然化后处理：静音压缩 + crossfade + trim
MOSS_AUDIO_POLISH_ENABLED=true
# 裁掉 chunk 首尾异常静音，减少长文本卡顿
MOSS_TRIM_SILENCE_ENABLED=true
# 低于该 dBFS 视为静音边缘
MOSS_TRIM_SILENCE_DB=-45
# 最终音频连续静音上限，超过会被压缩
MOSS_MAX_SILENCE_MS=480
# 非流式拼接 crossfade 时长
MOSS_CROSSFADE_MS=12
# AngeVoice 外层文本段之间补充的自然短停顿
MOSS_SEGMENT_PAUSE_MS=80
# MOSS runtime chunk pause 上限，防止 2-5 秒空白
MOSS_RUNTIME_PAUSE_MAX_MS=350

# 缓存保护：长文本命中率低，默认限制内存占用
KOKORO_CACHE_MAX_BYTES=536870912
KOKORO_CACHE_SKIP_TEXT_OVER_CHARS=1200
KOKORO_CACHE_SKIP_AUDIO_OVER_BYTES=20971520

# 中文网页/小说硬换行策略：auto 会合并段内单换行，保留空行段落
ANGEVOICE_SINGLE_NEWLINE_POLICY=auto

# MOSS 显存保护：8GB/P4/NAS 推荐保持开启
MOSS_VRAM_GUARD_ENABLED=true
MOSS_VRAM_SAFE_FREE_MB=1200
MOSS_VRAM_CRITICAL_FREE_MB=600
MOSS_LOW_VRAM_SEGMENT_LENGTH=96
MOSS_LOW_VRAM_MAX_NEW_FRAMES=280
MOSS_LOW_VRAM_TEXT_TOKENS=48
MOSS_DISABLE_FULL_CODEC_AFTER_OOM=true
MOSS_FULL_CODEC_OOM_COOLDOWN_SECONDS=600
# 显存快照缓存 TTL，避免流式过程中频繁 torch/nvidia-smi 查询造成卡顿。
MOSS_VRAM_SNAPSHOT_TTL_SECONDS=10
