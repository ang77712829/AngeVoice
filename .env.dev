# ============================================================
# AngeVoice — 开发环境
# 特点：轻量、快速启动、关闭生产特性
# 使用：cp .env.dev .env && docker compose up
# ============================================================

PYTHONUNBUFFERED=1
HF_HOME=/root/.cache/huggingface
HUGGINGFACE_HUB_CACHE=/root/.cache/huggingface/hub
KOKORO_HOST=0.0.0.0
KOKORO_PORT=8000
KOKORO_DEVICE=cpu
KOKORO_WORKERS=1
KOKORO_MAX_CONCURRENT_REQUESTS=2
KOKORO_REQUEST_TIMEOUT_SECONDS=120
KOKORO_MAX_TEXT_LENGTH=10000
KOKORO_SEGMENT_LENGTH=50
KOKORO_DEFAULT_VOICE=zm_010
KOKORO_DEFAULT_SPEED=1.0
KOKORO_STREAM_FORMAT=pcm_s16le
KOKORO_STREAM_BINARY_ENABLED=true
KOKORO_CACHE_ENABLED=true
KOKORO_CACHE_MAX_ITEMS=64
KOKORO_METRICS_ENABLED=true
KOKORO_QUEUE_STATUS_ENABLED=true
KOKORO_BATCH_ENABLED=true
KOKORO_BATCH_MAX_ITEMS=10
KOKORO_BATCH_CONCURRENCY=1
KOKORO_MP3_ENABLED=false
KOKORO_CORS_ORIGINS=*
# 开发环境通常不开 admin
# KOKORO_ADMIN_ENABLED=true
# KOKORO_API_KEY=dev-secret-123

# ---- MOSS-TTS-Nano 开发默认值 ----
ANGEVOICE_ENABLED_MODELS=kokoro,moss-nano-cpu
ANGEVOICE_DEFAULT_MODEL=kokoro
MOSS_EXECUTION_PROVIDER=cpu
MOSS_CUDA_ENABLED=false
MOSS_CPU_THREADS=2
MOSS_PROMPT_UPLOAD_MAX_BYTES=20971520
MOSS_PROMPT_AUDIO_MAX_SECONDS=10
MOSS_PROMPT_CACHE_MAX_ITEMS=8
MOSS_OUTPUT_PEAK_NORMALIZE_ENABLED=true
MOSS_OUTPUT_TARGET_PEAK=0.92
MOSS_OUTPUT_GAIN=1.0
