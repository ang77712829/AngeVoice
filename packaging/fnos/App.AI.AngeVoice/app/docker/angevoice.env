PYTHONUNBUFFERED=1

KOKORO_API_KEY=auto
KOKORO_ADMIN_ENABLED=true

ANGEVOICE_MODEL_SOURCE=modelscope
KOKORO_PREFETCH_VOICES=true

KOKORO_WORKERS=1
KOKORO_MAX_CONCURRENT_REQUESTS=1
KOKORO_REQUEST_TIMEOUT_SECONDS=300

ANGEVOICE_IDLE_TIMEOUT_SECONDS=600
ANGEVOICE_IDLE_CHECK_INTERVAL=30
ANGEVOICE_IDLE_UNLOAD_CURRENT=true

KOKORO_PUBLIC_STATUS_ENDPOINTS=true
KOKORO_RATE_LIMIT_QPS=0
KOKORO_RATE_LIMIT_BURST=5
