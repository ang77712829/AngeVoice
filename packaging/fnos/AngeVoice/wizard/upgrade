[
  {
    "stepTitle": "升级配置确认",
    "description": "升级不会删除已有模型和输出数据。请确认升级后的运行模式、访问端口、模型源与管理后台账号。",
    "items": [
      {
        "type": "text",
        "field": "wizard_http_port",
        "label": "服务端口",
        "initValue": "8101",
        "rules": [
          { "required": true, "message": "请输入端口号" },
          { "pattern": "^[0-9]{2,5}$", "message": "端口号必须是数字" }
        ]
      },
      {
        "type": "radio",
        "field": "COMPOSE_PROFILES",
        "label": "运行模式（GPU 仅支持 NVIDIA 显卡）",
        "initValue": "cpu",
        "options": [
          { "label": "CPU（推荐）— 无需 GPU，适用于 NAS / 家用服务器", "value": "cpu" },
          { "label": "GPU — NVIDIA CUDA 加速（需宿主机 Docker GPU 可用）", "value": "gpu" },
          { "label": "Legacy GPU — Tesla P4 / 较旧 CUDA 驱动兼容模式", "value": "legacy-gpu" }
        ],
        "rules": [
          { "required": true, "message": "请选择运行模式" }
        ]
      },
      {
        "type": "radio",
        "field": "wizard_model_source",
        "label": "模型下载源",
        "initValue": "modelscope",
        "options": [
          { "label": "ModelScope（推荐，国内网络）", "value": "modelscope" },
          { "label": "自动探测（自动选择可用源）", "value": "auto" },
          { "label": "Hugging Face（适合海外网络）", "value": "huggingface" }
        ],
        "rules": [
          { "required": true, "message": "请选择模型下载源" }
        ]
      }
    ]
  },
  {
    "stepTitle": "管理后台安全配置",
    "description": "管理后台使用此账号和密码登录；普通 TTS API Key 会在应用首次启动时自动生成，可登录后台查看或轮换。请勿使用默认弱密码。",
    "items": [
      {
        "type": "text",
        "field": "wizard_admin_username",
        "label": "管理员用户名",
        "initValue": "admin",
        "rules": [
          { "required": true, "message": "请输入管理员用户名" },
          { "min": 2, "max": 32, "message": "用户名长度应为 2 到 32 位" }
        ]
      },
      {
        "type": "password",
        "field": "wizard_admin_password",
        "label": "管理员密码",
        "rules": [
          { "required": true, "message": "请输入管理员密码" },
          { "min": 8, "max": 128, "message": "密码长度应为 8 到 128 位" }
        ]
      }
    ]
  }
]
