#!/bin/bash
# install_callback - 安装回调（向导完成后执行）
# env文件随FPK打包，这里只追加向导中用户填写的值

set -e

echo "[AngeVoice] 开始安装回调..."

# ========== 1. 创建数据目录 ==========
mkdir -p "$TRIM_PKGVAR/models"
mkdir -p "$TRIM_PKGVAR/outputs"
mkdir -p "$TRIM_PKGVAR/prompts"
mkdir -p "$TRIM_PKGVAR/logs"
mkdir -p "$TRIM_PKGETC"

echo "[AngeVoice] 数据目录已创建: $TRIM_PKGVAR"

# ========== 2. 更新env配置文件 ==========
# env文件随FPK打包到docker/angevoice.env，不需要重新生成
# 只把向导中用户填写的值追加/更新进去
ENV_FILE="$TRIM_PKGETC/angevoice.env"

# 兼容旧版：如果env文件不存在（升级场景），从FPK包内复制
if [ ! -f "$ENV_FILE" ] && [ -f "/var/apps/AngeVoice/app/docker/angevoice.env" ]; then
    cp "/var/apps/AngeVoice/app/docker/angevoice.env" "$ENV_FILE"
    echo "[AngeVoice] env文件从FPK包复制: $ENV_FILE"
fi

# 更新向导配置的值
update_env() {
    local key="$1"
    local val="$2"
    if [ -n "$val" ] && [ -f "$ENV_FILE" ]; then
        if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
            sed -i "s|^${key}=.*|${key}=${val}|" "$ENV_FILE"
        else
            echo "${key}=${val}" >> "$ENV_FILE"
        fi
        echo "[AngeVoice] 更新配置: ${key}=${val}"
    fi
}

# 管理员用户名
update_env "KOKORO_ADMIN_USERNAME" "$wizard_admin_username"

# 管理员密码
update_env "KOKORO_ADMIN_PASSWORD" "$wizard_admin_password"

# 模型源
update_env "ANGEVOICE_MODEL_SOURCE" "$wizard_model_source"

# 自动下载
update_env "KOKORO_PREFETCH_VOICES" "$wizard_auto_download"

echo "[AngeVoice] 安装回调完成"
exit 0
