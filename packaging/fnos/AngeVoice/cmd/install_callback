#!/bin/bash
# AngeVoice fnOS 安装后处理：仅校验向导输入并建立持久化目录。
# Docker 模式选择、端口、管理员凭据与模型源由固定 compose 直接读取向导环境变量；
# 不在 callback 中替换 compose 或写入镜像选择，避免 docker-project 已缓存编排内容后切换失败。
set -eu

log() { echo "[AngeVoice] $*"; }
fail() {
  local msg="$1"
  if [ -n "${TRIM_TEMP_LOGFILE:-}" ]; then
    echo "$msg" > "${TRIM_TEMP_LOGFILE}"
  fi
  echo "[AngeVoice] $msg" >&2
  exit 1
}

PORT="${wizard_http_port:-8101}"
PROFILE="${COMPOSE_PROFILES:-cpu}"
MODEL_SOURCE="${wizard_model_source:-modelscope}"

case "$PORT" in *[!0-9]*|'') fail "服务端口必须为数字。" ;; esac
[ "$PORT" -ge 1024 ] && [ "$PORT" -le 65535 ] || fail "服务端口必须在 1024 到 65535 之间。"
case "$PROFILE" in cpu|gpu|legacy-gpu) ;; *) fail "运行模式无效：${PROFILE}" ;; esac
case "$MODEL_SOURCE" in auto|modelscope|huggingface) ;; *) fail "模型下载源无效：${MODEL_SOURCE}" ;; esac
[ -n "${wizard_admin_username:-admin}" ] || fail "管理员用户名不能为空。"
[ -n "${wizard_admin_password:-admin123}" ] || fail "管理员密码不能为空。"

if command -v ss >/dev/null 2>&1 && ss -H -ltn 2>/dev/null | awk '{print $4}' | grep -Eq "[:.]${PORT}$"; then
  fail "端口 ${PORT} 已被占用，请返回上一步选择其他端口。"
fi

mkdir -p "${TRIM_PKGVAR}/models" "${TRIM_PKGVAR}/outputs" "${TRIM_PKGVAR}/prompts" \
  "${TRIM_PKGVAR}/credentials" "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/logs"
log "配置完成：profile=${PROFILE}, port=${PORT}, model_source=${MODEL_SOURCE}"
log "首次可使用 admin / admin123 登录；公网暴露前请在后台立即改密。"
exit 0
