#!/bin/bash
# config_callback — 配置更新回调脚本
# 功能：用户在应用设置中修改配置向导时，更新 angevoice.env
# 注意：env 变更需重启容器后生效（飞牛 → 应用中心 → AngeVoice → 重启）
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=_lib.sh
source "${SCRIPT_DIR}/_lib.sh"

APP_NAME="${TRIM_APPNAME:-AngeVoice}"
APP_DOCKER_DIR="${TRIM_APPDEST}/docker"
ENV_FILE="${APP_DOCKER_DIR}/angevoice.env"

[ -f "${ENV_FILE}" ] || exit 0

MODEL_SOURCE="${wizard_model_source:-}"
case "${MODEL_SOURCE}" in
  ''|auto|huggingface|modelscope) ;;
  *) MODEL_SOURCE="modelscope" ;;
esac

# 修复：原始源码使用了错误的 KOKORO_ADMIN_USERNAME/PASSWORD，
# 正确变量名为 ANGEVOICE_ADMIN_USERNAME/PASSWORD
upsert_env "ANGEVOICE_ADMIN_USERNAME" "${wizard_admin_username}"
upsert_env "ANGEVOICE_ADMIN_PASSWORD" "${wizard_admin_password}"
upsert_env "ANGEVOICE_MODEL_SOURCE"   "${MODEL_SOURCE}"

# 同步到 @appcenter 运行目录
sync_to_appcenter

log "配置已更新；如变更未立即生效，请在飞牛中重启 AngeVoice 容器。"
exit 0
