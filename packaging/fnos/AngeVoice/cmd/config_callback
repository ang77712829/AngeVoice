#!/bin/bash
# 向导配置将由 fnOS 保存为环境变量，下一次应用启动时由 docker-project 重新用于 compose 插值。
set -eu
log() { echo "[AngeVoice] $*"; }
PROFILE="${COMPOSE_PROFILES:-cpu}"
PORT="${wizard_http_port:-8101}"
case "$PROFILE" in cpu|gpu|legacy-gpu) ;; *) exit 1 ;; esac
case "$PORT" in *[!0-9]*|'') exit 1 ;; esac
[ "$PORT" -ge 1024 ] && [ "$PORT" -le 65535 ] || exit 1
log "设置已保存：profile=${PROFILE}, port=${PORT}。请停止并重新启动应用以应用新的容器配置。"
exit 0
