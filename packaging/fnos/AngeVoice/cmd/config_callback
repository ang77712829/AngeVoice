#!/bin/bash
# 向导配置由 fnOS 保存为环境变量；下一次应用启动时 docker-project 会在解析 compose 时应用 COMPOSE_PROFILES。
set -eu
PROFILE="${COMPOSE_PROFILES:-cpu}"
PORT="${wizard_http_port:-8101}"
case "$PROFILE" in cpu|gpu|legacy-gpu) ;; *) exit 1 ;; esac
case "$PORT" in *[!0-9]*|'') exit 1 ;; esac
[ "$PORT" -ge 1024 ] && [ "$PORT" -le 65535 ] || exit 1
echo "[AngeVoice] 设置已保存：profile=${PROFILE}, port=${PORT}。请停止并重新启动应用以应用新的容器模式。"
exit 0
