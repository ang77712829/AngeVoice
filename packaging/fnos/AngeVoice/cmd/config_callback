#!/bin/bash
# config_callback - 应用设置变更回调
# 当用户在管理后台修改配置时执行
set -e

echo "[AngeVoice] 配置变更回调..."

# 更新env文件中的管理配置
ENV_FILE="${TRIM_PKGETC:-/vol3/@appconf/AngeVoice}/angevoice.env"
[ -f "$ENV_FILE" ] || exit 0

update_env() {
    local key="$1" val="$2"
    [ -z "$val" ] && return
    if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${val}|" "$ENV_FILE"
    else
        echo "${key}=${val}" >> "$ENV_FILE"
    fi
}

# 更新向导变量（如果fnOS传入了新值）
update_env "KOKORO_ADMIN_USERNAME" "$wizard_admin_username"
update_env "KOKORO_ADMIN_PASSWORD" "$wizard_admin_password"
update_env "ANGEVOICE_MODEL_SOURCE" "$wizard_model_source"

echo "[AngeVoice] 配置回调完成"
exit 0
