#!/bin/bash
# config_callback - 配置向导回调（用户修改设置后执行）

set -e

echo "[AngeVoice] 开始配置回调..."

ENV_FILE="$TRIM_PKGETC/angevoice.env"

# 更新用户修改的配置项
update_env() {
    local key="$1"
    local val="$2"
    if [ -n "$val" ]; then
        if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
            sed -i "s|^${key}=.*|${key}=${val}|" "$ENV_FILE"
        else
            echo "${key}=${val}" >> "$ENV_FILE"
        fi
        echo "[AngeVoice] 更新配置: ${key}=${val}"
    fi
}

# 更新模型源
update_env "ANGEVOICE_MODEL_SOURCE" "$wizard_model_source"

# 更新管理员用户名
update_env "ANGEVOICE_ADMIN_USERNAME" "$wizard_admin_username"

# 更新管理员密码
update_env "ANGEVOICE_ADMIN_PASSWORD" "$wizard_admin_password"

# ========== 同步端口到ui/config ==========
# 当用户在应用设置中修改端口时，同步更新ui/config的port字段
CONFIG_FILE="/var/apps/AngeVoice/target/ui/config"
if [ -n "$TRIM_SERVICE_PORT" ] && [ -f "$CONFIG_FILE" ]; then
    python3 -c "
import json, sys
try:
    with open('$CONFIG_FILE') as f:
        config = json.load(f)
    port_str = str('$TRIM_SERVICE_PORT')
    changed = False
    for entry_type in config:
        for key in config[entry_type]:
            if config[entry_type][key].get('port') != port_str:
                config[entry_type][key]['port'] = port_str
                changed = True
    if changed:
        with open('$CONFIG_FILE', 'w') as f:
            json.dump(config, f, indent=4)
            f.write('\n')
        print('[AngeVoice] ui/config端口已同步: ' + port_str)
except Exception as e:
    print('[AngeVoice] 端口同步失败: ' + str(e), file=sys.stderr)
" 2>&1
fi

echo "[AngeVoice] 配置回调完成"
exit 0
