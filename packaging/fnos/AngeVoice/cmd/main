#!/bin/bash
# Docker 应用启停由 fnOS docker-project 管理；这里仅报告活动 profile 的容器状态。
set -u

is_running() {
  local name
  for name in angevoice-cpu angevoice-gpu angevoice-legacy-gpu; do
    if docker inspect "$name" >/dev/null 2>&1; then
      [ "$(docker inspect -f '{{.State.Status}}' "$name" 2>/dev/null)" = "running" ]
      return $?
    fi
  done
  return 1
}

case "${1:-}" in
  start|stop)
    exit 0
    ;;
  status)
    if is_running; then exit 0; else exit 3; fi
    ;;
  *)
    exit 1
    ;;
esac
