#!/bin/bash
# 升级后处理：持久化数据保留；新版 compose 在启动前直接使用升级向导透传的 COMPOSE_PROFILES。
set -eu
PROFILE="${COMPOSE_PROFILES:-cpu}"
case "$PROFILE" in cpu|gpu|legacy-gpu) ;; *) exit 1 ;; esac
mkdir -p "${TRIM_PKGVAR}/models" "${TRIM_PKGVAR}/outputs" "${TRIM_PKGVAR}/prompts" \
  "${TRIM_PKGVAR}/credentials" "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/logs"
echo "[AngeVoice] 升级完成：profile=${PROFILE}；模型、音色、输出、凭据与运行配置目录均已保留。"
exit 0
