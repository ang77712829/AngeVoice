#!/bin/bash
# upgrade_callback — 升级回调脚本
# 功能：不覆盖已有用户 env；补充新增字段；迁移旧变量名
# 注意：设备类型由 cmd/main start 自动检测
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=_lib.sh
source "${SCRIPT_DIR}/_lib.sh"

APP_NAME="${TRIM_APPNAME:-AngeVoice}"
APP_DOCKER_DIR="${TRIM_APPDEST}/docker"
DATA_DIR="${TRIM_PKGVAR}"
ENV_FILE="${APP_DOCKER_DIR}/angevoice.env"

mkdir -p "${DATA_DIR}/models" "${DATA_DIR}/outputs" "${DATA_DIR}/prompts" "${DATA_DIR}/logs" "${APP_DOCKER_DIR}"
[ -f "${ENV_FILE}" ] || touch "${ENV_FILE}"
cp "${ENV_FILE}" "${ENV_FILE}.bak.$(date +%Y%m%d%H%M%S)" 2>/dev/null || true

# 只补充不存在的字段，不覆盖用户已有配置
ensure_env "PYTHONUNBUFFERED"               "1"
ensure_env "KOKORO_API_KEY"                 "auto"
ensure_env "KOKORO_ADMIN_ENABLED"           "true"
ensure_env "ANGEVOICE_ADMIN_USERNAME"       "admin"
ensure_env "ANGEVOICE_ADMIN_PASSWORD"       "admin123456"
ensure_env "ANGEVOICE_MODEL_SOURCE"         "modelscope"
ensure_env "KOKORO_PREFETCH_VOICES"         "true"
ensure_env "ANGEVOICE_IDLE_TIMEOUT_SECONDS" "600"
ensure_env "ANGEVOICE_IDLE_CHECK_INTERVAL"  "30"
ensure_env "ANGEVOICE_IDLE_UNLOAD_CURRENT"  "true"
ensure_env "ANGEVOICE_API_KEY_FILE"         "/app/outputs/.angevoice-api-key"

# 迁移：旧版本错误地写了 KOKORO_ADMIN_USERNAME/PASSWORD
old_user="$(get_env_val KOKORO_ADMIN_USERNAME || true)"
old_pass="$(get_env_val KOKORO_ADMIN_PASSWORD || true)"
[ -n "${old_user}" ] && ensure_env "ANGEVOICE_ADMIN_USERNAME" "${old_user}"
[ -n "${old_pass}" ] && ensure_env "ANGEVOICE_ADMIN_PASSWORD" "${old_pass}"

# 同步到 @appcenter 运行目录
sync_to_appcenter

# 注意：设备类型由 cmd/main start 在下次启动时自动检测
log "升级回调完成；设备类型将在下次启动时由 cmd/main 自动检测"
exit 0
